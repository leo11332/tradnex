{
  "expo": {
    "name": "tradnex",
    "slug": "tradnex",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-bdv.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/app-icon-bdv.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.placeholder.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSHealthShareUsageDescription": "TRADNEX reads your heart rate, HRV, and sleep data to monitor your trading performance.",
        "NSHealthUpdateUsageDescription": "TRADNEX may write stress scores to Apple Health."
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.security.application-groups": [
          "group.com.placeholder.app.onesignal"
        ],
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-bdv.png",
        "backgroundColor": "#000000"
      },
      "package": "com.placeholder.app",
      "permissions": [
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_HEART_RATE_VARIABILITY"
      ]
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "production"
        }
      ],
      ["react-native-health-connect", {}],
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "scheme": "tradnex",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://3yq422x8b2j2qmcf8sgaapzq85kyna2q.app.specular.dev",
      "revenueCatApiKeyIos": "appl_utGCQaVyDphvrqLpRhtFNmzWmlF",
      "revenueCatApiKeyAndroid": "goog_AjjXWfruYNRaDcYLDLnQJPRPHyP",
      "revenueCatEntitlementId": "pro",
      "nativelyProjectId": "3455cb83-b719-449e-ba13-570a083b8c83",
      "revenueCatTestApiKeyIos": "test_MKLGDWXtFDPwQwhtzPKqnVPrNSX",
      "revenueCatTestApiKeyAndroid": "test_MKLGDWXtFDPwQwhtzPKqnVPrNSX",
      "oneSignalAppId": "8c6bf0c9-4c60-4ae4-bf97-d73d912964ec"
    }
  }
}
